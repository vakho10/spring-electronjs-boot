{
  "name": "spring-electronjs-boot",
  "version": "1.0.0",
  "description": "Electron + Vite + TypeScript front end for the Spring Boot backend",
  "main": "./out/main/index.js",
  "author": "Vakho",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env JAVA_PROFILE=dev electron-vite dev",
    "stage": "cross-env JAVA_PROFILE=stage electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "make:runtime": "node scripts/make-runtime.mjs",
    "pack:dir": "npm run make:runtime && electron-vite build && electron-builder --dir",
    "dist:win": "npm run make:runtime && electron-vite build && electron-builder --win --publish never",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "cross-env": "^10.0.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.0.0"
  }
}
